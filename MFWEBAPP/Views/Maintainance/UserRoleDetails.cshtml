
@{
    ViewData["Title"] = "UserRoleDetails";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}


<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header"><strong> User Role </strong></div>
            <div class="card-body card-block">

                <button type="button" class="btn btn-primary btn-bg" data-toggle="modal" onclick="_userRoles.changePopupHeader(1);" data-target="#mediumModal" data-backdrop="static" data-keyboard="false"> <i class="fa fa-plus-circle" style="font-size:24px;"></i></button>



                <!--Modal-->
                <form name="frmUserRole" id="frmUserRole" method="post">
                    <div class="modal fade" id="mediumModal" tabindex="-1" role="dialog" aria-labelledby="mediumModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-sm" role="document">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" name="mediumModalLabel" id="mediumModalLabel">Add User Role</h5>
                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="_userRoles.clearForm();">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <div class="modal-body">
                                    <p>

                                        <div class="row form-group ">
                                                <div class="col-lg-12 col-md-6 col-sm-6 col-xs-12 ">

                                                    <label for="street" class="form-control-label">Role<b style="color:red">*</b></label>
                                                    <input type="text" placeholder="Role" id="roleName" name="roleName" maxlength="35" class="form-control">
                                                    <label id="roleName-error" class="error" for="roleName" style="display:block"></label>



                                               
                                            </div>
                                        </div>



</p>
                                </div>
                                <div class="modal-footer">

                                    <button type="submit" id="addUserRoleDataBtn" class="btn btn-success fc-center"><i class="fa fa-save"></i> &nbsp;Save </button>

                                </div>
                            </div>
                        </div>
                    </div>

                </form>


                </br>

                <div class="col-lg-12 col-md-12 col-sm-12 col-xl-12 no-padding">
                    <div class="card" id="maincard" style="display:none;">
                        <div class="card-body" style="background-color:#fff !important;">

                            <div class="table-responsive">

                                <div align="center" id="divuserroledetails" name="divuserroledetails" style="position: relative;max-height: 350px;min-height:250px;overflow: auto;display: block;">

                                </div>

                            </div>
                        </div>
                    </div>




                </div>



                <!--Table-->


            </div>
        </div>

    </div>
</div>


@section Scripts{


    <script src="~/ClientApp/AddUserRoles/AddUserRoles.Controller.js"></script>
    <script src="~/ClientApp/AddUserRoles/AddUserRoles.Validator.js"></script>


}

