<div class="modal fade" id="mediumModal" tabindex="-1" role="dialog" aria-labelledby="mediumModalLabel" aria-hidden="true" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="mediumModalLabel">Add New</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="frmRestictAddNew" name="frmRestictAddNew" method="post">


                    <p>

                        <div class="col-lg-6 col-md-5 col-sm-12 col-xs-12 offset-3">
                            <div class="form-group">
                                @*<select name="ddlPopCombo" id="ddlPopCombo" style="display:none;" class="form-control-lg form-control fa-external-link" >*@
                                <select name="ddlPopCombo" id="ddlPopCombo" style="display:none;" class=" form-control " required>
                                    <option value="0">------------Select------------------</option>

                                </select>
                                @*<label id="txtPop-error" class="error" for="txtPop" style="display:block;"></label>*@

                            </div>
                            <div class="form-group">
                                @*<input type="text" id="txtPop" style="display:none;" name="txtPop" class="form-control-lg form-control fa-external-link" placeholder="" />*@
                                <input type="text" id="txtPop" style="display:none;" name="txtPop" class=" form-control " placeholder="">
                                <label id="txtPop-error" class="error" for="txtPop" style="display:block;"></label>

                            </div>
                        </div>
                        <div class="text-center">

                            <button type="button" id="saveSubmit" name="saveSubmit" class="btn btn-success waves-effect" onclick="_RestrictMemberCreation.AddNewRestiction(0);">Save</button>

                        </div>

                    </p>

                </form>
            </div>
            @*<div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary">Confirm</button>
                </div>*@
        </div>
    </div>
</div>


