
@{
    ViewData["Title"] = "AddVendor";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}

<div class="">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <strong class="card-title">Add Vendor</strong>
            </div>
            <div class="card-body card-block">
                <form name="frmAccountsApproval" id="frmAccountsApproval" method="post" class="form-horizontal">

                    <div class="row form-group">
                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12">
                            <label for="cc-payment" class="control-label mb-1">Select Vendor<b style="color:red">*</b></label>
                            <select name="ddlVendor" id="ddlVendor" class="form-control">
                                <option value="0"> ------------ Select ------------ </option>
                            </select>
                        </div>
                        @*</div>

        <div class="row form-group">*@
                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label class="control-label mb-1">Enter Address<b style="color:red">*</b></label>
                                <input type="text" id="addres" name="Addres" placeholder="Enter Address" class="form-control" maxlength="100">
                                <label id="payType-error" class="error" for="payType" style="display:block"></label>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12">
                            <label for="cc-payment" class="control-label mb-1">State<b style="color:red">*</b></label>
                            <select name="ddlState" id="ddlState" class="form-control">
                                <option value="0"> ------------ Select State ------------ </option>
                            </select>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label class="control-label mb-1">GSTIN<b style="color:red">*</b></label>
                                <input type="text" id="gstin" name="gstin" placeholder="GSTIN" class="form-control" maxlength="15">
                                <label id="gstin-error" class="error" for="gstin" style="display:block"></label>
                            </div>
                        </div>
                    </div>

             
                    <div class="text-right">
                        <button type="button" class="btn btn-success" id="submit">Confirm</button>
                        <button type="button" class="btn btn-danger" id="exit">Exit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts{

    <script src="~/ClientApp/ServiceFee/AddVendorFee.js"></script>
}