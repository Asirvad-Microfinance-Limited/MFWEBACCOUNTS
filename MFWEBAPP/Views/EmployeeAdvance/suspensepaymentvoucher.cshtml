                        <th style="font-size: 15px; border-bottom: 1px solid black" align="left">Tradt</th>
                        <th style="font-size: 15px; border-bottom: 1px solid black" align="left">Descr</th>
                        <th style="font-size: 15px; border-bottom: 1px solid black" align="left">Debit</th>
                        <th style="font-size: 15px; border-bottom: 1px solid black" align="left">Credit</th>5
                    </tr>
                    <tr>
                        <td style="font-size: 15px;border-bottom:1px solid black" align="left">@Model.queryResult[0].param2.Split("#")[0]</td>
                        <td style="font-size: 15px;border-bottom:1px solid black" align="left">@Model.queryResult[0].param2.Split("#")[1]</td>
                        <td style="font-size: 15px;border-bottom:1px solid black" align="left">20/12/2023</td>
                        <td style="font-size: 15px;border-bottom:1px solid black" align="left">@Model.queryResult[0].param2.Split("#")[2]</td>
                        <td style="font-size: 15px;border-bottom:1px solid black" align="left">@Model.queryResult[0].param2.Split("#")[3]</td>
                        <td style="font-size: 15px;border-bottom:1px solid black" align="left">@Model.queryResult[0].param2.Split("#")[4]</td>

                    </tr>

                    <tr>
                        <td style="font-size: 15px;border-bottom:1px solid black" align="left">@Model.queryResult[1].param2.Split("#")[0]</td>
                        <td style="font-size: 15px;border-bottom:1px solid black" align="left">@Model.queryResult[1].param2.Split("#")[1]</td>
                        <td style="font-size: 15px;border-bottom:1px solid black" align="left">20/12/2023</td>
                        <td style="font-size: 15px;border-bottom:1px solid black" align="left">@Model.queryResult[1].param2.Split("#")[2]</td>
                        <td style="font-size: 15px;border-bottom:1px solid black" align="left">@Model.queryResult[1].param2.Split("#")[3]</td>
                        <td style="font-size: 15px;border-bottom:1px solid black" align="left">@Model.queryResult[1].param2.Split("#")[4]</td>

                    </tr>

                    <tr>
                        <td style="font-size: 15px;" align="left"></td>
                        <td style="font-size: 15px;" align="left"></td>
                        <td style="font-size: 15px;" align="left">Total</td>
                        <td style="font-size: 15px;" align="left"></td>
                        <td style="font-size: 15px;" align="left">@Model.queryResult[2].param2.Split("#")[3]</td>
                        <td style="font-size: 15px;" align="left">@Model.queryResult[2].param2.Split("#")[3]</td>

                    </tr>

                </table>

                <h3 style="text-align:center"> THE USE ID FOR THE JOURNEL VOUCHER:- DEPOSIT. </h3>


