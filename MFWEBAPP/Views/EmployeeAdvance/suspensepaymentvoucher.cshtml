                <h3 style="text-align:center"> JOURNEL VOUCHER OF @Model.queryResult[0].param1.Split("#")[2] </h3>

                <table style="width:100%">
                    <tr>
                        <th>
                            <span style="font-size: 15px;float:left">@Model.queryResult[0].param1.Split("#")[3] </span>

                        </th>
                        @*<th>
                            <span style="font-size: 15px;float:right">05:42:42 PM</span>
                        </th>*@
                    </tr>

                </table>




                @*<div class="bind" style="width:98%; border:1px solid black; border-collapse:collapse ;border-color:#242323 ;padding-top:10px;padding-bottom:10px;padding-left:8px;padding-right:8px">*@

                <table style="width:100%;border:1px solid black" class="address">
                    <tr>
