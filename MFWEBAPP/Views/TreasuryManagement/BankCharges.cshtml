@{
    ViewData["Title"] = "Bank Charges";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}

<div class="card">
    <div class="card-header">
        <strong class="card-title">Approval Of Bank Charges</strong>
    </div>
  
    <div class="card-body">

        <div class="row mb-2">
            <div class="col-md-2">
                <div class="form-group">
                    <input type="radio" id="rdproc" name="bankcharges" value="1" >
                    <label for="html">Processing Fee</label>
                </div>
            </div>
            <div class="col-md-2">
                <div class="form-group">
                    <input type="radio" id="rddoc" name="bankcharges" value="2" >
                    <label for="css">Documentation Fee</label>
                </div>
            </div>
            <div class="col-md-2">
                <div class="form-group">
                    <input type="radio" id="rdoth" name="bankcharges" value="3" >
                    <label for="javascript">Other Fee</label>
                </div>
            </div>
            <div class="col-md-2">
                <div class="form-group">
                    <input type="radio" id="rdnoc" name="bankcharges" value="4" >
                    <label for="javascript">IPO NOC Fee</label>
                </div>
            </div>
        </div>
        <div class="row mb-2" id="divfi" style="display:none">
            <div class="col-md-6">
                <div class="form-group">
                    <label for="fundcat">Select Fund<span class="text-danger">*</span></label>
                    <select class="custom-select form-control" id="ddl_Loan"  name="Select Fund" > </select>
                </div>
            </div>
        </div>
