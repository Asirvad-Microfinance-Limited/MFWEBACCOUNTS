@{
    ViewData["Title"] = "NCDBondAvailment";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}
<div class="row">
    <div class="col-12">
        <div class="card ">
            <div class="card-header">+
                <strong class="card-title">New Debenture Request</strong>
            </div>
           
                <div class="card-body">
                    <div class="row">
                    <div class="col-md-3"></div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fundcat">Fund Category : <span class="text-danger">*</span></label>
                                <select class="custom-select form-control" id="ddlCategory"  name="Fund Category">
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fundsubcat">Fund Sub Category : <span class="text-danger">*</span></label>
                                <select class="custom-select form-control" id="ddlSubCat" name="Fund Sub Category" >
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3" id="divFiType" style="display:none">  
                            <div class="form-group">
                                <label for="fundcat">Financial Institution Type : <span class="text-danger">*</span></label>
                            <select class="custom-select form-control" id="ddlFiType" name="FinancialInstitutionType">
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3" id="divFi" style="display:none">
                            <div class="form-group">
                                <label for="fundsubcat">Financial Institution :<span class="text-danger">*</span></label>
                                <select class="custom-select form-control" id="ddlFi"  name="FinancialInstitution">
                                </select>
                            </div>

                        </div>

                        <div class="col-md-6" id="divPISeries" style="display:none">
                            <div class="form-group">
                                <label for="txtPublicIssueSeries">Series : <span class="text-danger">*</span></label>
                                <input type="text" class=" form-control" maxlength="100" id="txtPblcIssueSeries" name="PublicIssueSeries"  />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="txtIsinNo">ISIN No : <span class="text-danger">*</span></label>
                                <input type="text" class=" form-control" maxlength="12" id="txtIsinNo" name="ISIN" oninput="this.value = this.value.replace(/[^a-zA-Z0-9]/g, '');" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="txtRating">Rating : <span class="text-danger">*</span></label>
                                <input type="text" class=" form-control" maxlength="100" id="txtRating" style="width:100%" name="Rating"  />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fundcat">Amount:<span class="text-danger">*</span></label>
                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                     
                                    </div>
                                    <input type="text" id="txtMatAmtPrinc" maxlength="15" class="form-control" name="LoanAmount"   oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" />
                                </div>
                                <small id="LoanAmtWords" class="form-text text-muted"></small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fundcat">Interest Rate : <span class="text-danger">*</span></label>
                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                      
                                    </div>
                                    <input type="text" class="form-control" id="txtintrate" title="InterestRate" maxlength="5" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" >
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fundcat">Interest Method : <span class="text-danger">*</span></label>
                                <select class="custom-select form-control" id="ddlintresttype"  name="InterestType"></select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fundcat">Principal Method : <span class="text-danger">*</span></label>
                                <select class="custom-select form-control" id="ddlprinciple"  name="Principletype"></select>
                            </div>
                        </div>





                      @*   <div class="col-md-3">
                            <div class="form-group">
                                <label for="txtAllotmentDate">Allotment Date : <span class="text-danger">*</span></label>
                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                      
                                    </div>
                                    <input type="text" class="form-control" id="txtAllotmentDate" name="AllotmentDate" autocomplete="off" title="Allotment Date" onkeypress="return false" />
                                </div>
                            </div>
                        </div> *@


                    <div class="col-md-3" id="datepickerDate">
                        <div class="form-group">
                            <label for="datepicker" class=" form-control-label mb-1">Allotment Date</label><b style="color:red">*</b>
                            <input class="form-control datepicker " id="txtAllotmentDate" name="dtToDate" type="text" readonly placeholder="mm/dd/yyyy" />
                            <label id="dtFromDate-error" class="error" for="dtToDate" style="display:block"></label>
                        </div>
                    </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="txtTenure">Tenure: <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="txtTenure"  title="Tenure" maxlength="4" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" >
                            </div>
                        </div>

                    </div>
                    <div class="row">


                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fundcat">Maturity Date : <span class="text-danger">*</span></label>

                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                      
                                    </div>
                                    <input type="text" class="form-control" id="txtMaturityDate" name="MaturityDate" title="Maturity Date"  disabled="disabled" />
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fundcat">Security Margin: </label>
                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                       
                                    </div>
                                    <input type="text" class="form-control" id="txtsecuritymarginamt" title="securitymargin" maxlength="5" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fundcat">Processing Fee :<span class="text-danger">*</span></label>
                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                       
                                    </div>
                                    <input type="text" id="txtProcessFee" maxlength="15" class="form-control" name="ProcessingFee"  oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" />
                                </div>
                                <small id="PFAmtWords" class="form-text text-muted"></small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fundcat">Other Cost :<span class="text-danger">*</span></label>
                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                        
                                    </div>
                                    <input type="text" id="txtOtherCost" maxlength="15" class="form-control" name="OtherCost"  oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" />
                                </div>
                                <small id="OCAmtWords" class="form-text text-muted"></small>
                            </div>
                        </div>
                    </div>
                    <br><br>
                    <div class="row" id="divUSDBond">
                        <div class="col-md-3" id="divRateTerm">
                            <div class="form-group">
                                <label for="fundcat">Rate Term: </label>
                                <input type="text" class="form-control" id="txtRateTerm"  title="Rate Term" />
                            </div>
                        </div>
                        <div class="col-md-3" id="divHedgeType">
                            <div class="form-group">
                                <label for="txtHedgeType">Hedging Type: <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="txtHedgeType"  title="Rate Term" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fundcat">Amount in USD:<span class="text-danger">*</span></label>
                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                       
                                    </div>
                                    <input type="text" id="txtUsdAmt" maxlength="15" class="form-control" name="USDAmount"   oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" />
                                </div>
                                <small id="UsdAmtWords" class="form-text text-muted"></small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="fundcat">Conversion Rate INR:<span class="text-danger">*</span></label>
                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                       
                                    </div>
                                    <input type="text" id="txtInrRate" maxlength="15" class="form-control" name="InrRate"  oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" />
                                </div>
                                <small id="InrAmtWords" class="form-text text-muted"></small>
                            </div>
                        </div>
                    </div>
                    <div class="row" id="divtermloan">
                        <div class="col-md-12 my-3 text-center" id="divterm1">
                            <div class="form-group">

                            <h4 class="card-title"> <strong>Upload Repayment Shedule</strong> </h4>
                            </div>
                        </div>

           
                       
                    </div>

