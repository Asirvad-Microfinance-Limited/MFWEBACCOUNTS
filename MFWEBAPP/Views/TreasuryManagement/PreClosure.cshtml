        <div class="row">
            <div class="col-md-3">
                <div class="form-group">
                    <label for="fundcat">Balance Loan Amount <span class="text-danger">*</span> </label>
                    <input type="text" class="form-control" maxlength="15" id="txtloanbal" title="Loan Balance" onclick="" onkeyup="IntAmtWords.innerHTML=AmountToWords(this.value)" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" />
                    <small id="LoanBalWords" class="form-text text-muted"></small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label for="fundcat">Balance Interest Amount <span class="text-danger">*</span></label>
                    <input type="text" id="txtIntAmt" maxlength="15" class="form-control" name="Interest Amount" onclick="" onkeyup="IntAmtWords.innerHTML=AmountToWords(this.value)" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" />
                    <small id="IntAmtWords" class="form-text text-muted"></small>
                </div>
            </div>
            <div class="col-md-3" id="divMainacct">
                <div class="form-group">
                    <label for="fundcat">Main Account <span class="text-danger">*</span></label>
                    <div style="width:100%;">
                        <select id="ddl_mainAcc" class="custom-select form-control" name="Select Main Account"></select>
                    </div>
                    <small id="LoanAccName" class="form-text text-muted"></small>
                </div>
            </div>
            <div class="col-md-3" id="subacst" style="display:none">
                <div class="form-group">
                    <label for="fundcat">Sub Account<span class="text-danger">*</span></label>
                    <div style="width:100%;">
                        <select id="ddl_SubAcc" style="width:100%" class="custom-select form-control" name="Select Sub Account"></select>
                    </div>
                    <small id="LoanSubAccName" class="form-text text-muted"></small>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-2" id="divintfinmainbnk" style="display:none">
                <label for="fundcat"> Finance Cost Main Bank<span class="text-danger">*</span></label>
                <div style="width:100%;">
                    <select id="ddl_intfc_main_bnk" class="custom-select form-control" name="Select Sub Id" ></select>
                </div>
            </div>
            <div class="col-md-2" id="divintfinsubbnk" style="display:none">
                <label for="fundcat">Finance Cost Sub Bank<span class="text-danger">*</span></label>
                <div style="width:100%;">
                    <select id="ddl_intfc_sub_bnk" class="custom-select form-control" name="Select Sub Id" ></select>
                </div>
            </div>
            <div class="col-md-2" id="divintfinsubid" style="display:none">
                <label for="fundcat">Finance Cost Contra Id<span class="text-danger">*</span></label>
                <div style="width:100%;">
                    <select id="ddl_IfSubid" class="custom-select form-control" name="Select Sub Id"></select>
                </div>
            </div>
        </div>
    </div>
    <div class="card-footer">
        <div class="text-end">
            <input id="btnconfirm" type="button" value="Confirm" class="btn btn-primary" onclick="return ConfirmLoanClosure();" />
            <input id="btnexit" type="button" value="Exit" class="btn btn-danger" onclick="return exitPage();" />
        </div>
    </div>
    </div>
<input id="hdUserId" type="hidden" runat="server" />
<input id="hdBranchId" type="hidden" runat="server" />
<input id="hdFirmId" type="hidden" runat="server" />
<input id="hdPag" type="hidden" runat="server" />
<input id="hdMainAcc" type="hidden" runat="server" />
<input id="hdSubAcc" type="hidden" runat="server" />
<input id="hdBrid" type="hidden" runat="server" />
<input id="hdnLoanMainAcc" type="hidden" runat="server" />
<input id="hdnLoanSubAcc" type="hidden" runat="server" />
<input id="hdnSubAccStatus" type="hidden" runat="server" />
<input id="hdTotal" type="hidden" runat="server" />




