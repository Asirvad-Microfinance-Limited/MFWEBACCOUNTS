                    <label for="fundcat">Select Financial Institution<span class="text-danger">*</span></label>
                    <select class="custom-select form-control" id="ddlFi" name="FinancialInstitution" > </select>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6" id="divselectFund">
                <div class="form-group">
                    <label for="fundcat">Select Fund<span class="text-danger">*</span></label>
                    <select class="custom-select form-control" id="ddlLoans" name="Fund" getTablePreCloseLoanDtlsEmi()"> </select>
                </div>
            </div>
        </div> 


