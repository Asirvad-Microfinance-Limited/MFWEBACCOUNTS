                            </div>
                        </div>
                        <div class="col-md-3" id="divAmount">
                            <label for="fundcat">Amount<span class="text-danger">*</span></label>
                            <input type="text" id="txtPayAmount" maxlength="15" class="form-control" name="PayAmount">

                            <small id="AmtWords" class="form-text text-muted"></small>
                        </div>

                        <div class="col-md-3" id="amntt">
                            <label for="fundcat"> Difference Amount</label>
                            <input type="text" id="balance" maxlength="15" class="form-control" name="pyamt">
                            <small id="amtn" class="form-text text-muted"></small>
                        </div>
                        <div class="col-md-3" id="divbllms" readonly="readonly" style="display:none">
                            <label for="fundcat"> Calculated interest amount</label>
                            <input type="text" id="bllms" maxlength="15" class="form-control" name="lmsreport">

                            <small id="amtn" class="form-text text-muted"></small>
                        </div>
                        <div class="col-md-3" id="divamtbal" style="display:none">
                            <label for="fundcat"> Ledger Amount</label>
                            <input type="text" id="amtbalanace" maxlength="15" class="form-control" name="PayAmountbal">

                            <small id="amtball" class="form-text text-muted"></small>
                        </div>


                        @* 
                        <div class="col-md-3" id="divamtbal">
                            <div class="col-md-2" id="divamtbalance">
                            <label for="fundcat">Ledger balance <span class="text-danger">*</span></label>
                            <input type="text" id="amtbalanace" maxlength="15" class="form-control" name="PayAmountbal">

                            <small id="amtball" class="form-text text-muted"></small>
                        </div>
 *@












                        <div class="col-md-3 my-4">
                            <input id="btnAdd" type="button" value="Add" class="btn btn-success">
                        </div>

                        <div class="col-md-3" id="DivMainAcc">
                            <div class="form-group">
                                <label for="fundcat">Main Account<span class="text-danger">*</span></label>
                                <div>
                                    <select id="ddl_mainAcc" style="width:100%" class="custom-select form-control" name="Select Main Account">
                                    </select>
                                </div>
                                <small id="LoanAccName" class="form-text text-muted"></small>
                            </div>
                        </div>
                        <div class="col-md-3" id="ddlsubacsts" style="display:none">
                            <div class="form-group">
                                <label for="fundcat">Sub Account<span class="text-danger">*</span></label>
                                <div style="width:100%;">
                                    <select id="ddl_SubAcc" style="width:100%" class="custom-select form-control" name="Select Sub Account"></select>
                                </div>
                                <small id="LoanSubAccName" class="form-text text-muted"></small>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12" id=" ShwCrTbl">
                            <div class="form-group">
                                <div class="table-responsive">
                                    <table class="table table-hover table-success" id="tblPaymentDtl">
                                        <thead class="bg-success text-white">
                                            <tr>
                                            </tr>
                                        </thead>
                                        <tbody class="border border-dark"></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row" id="txtfield" style="display:none">
                        <div class="col-md-3" id="divTotal">
                            <label for="fundcat">Total Amount</label>
                            <input type="text" class="form-control" style="color:red" id="txt_tot" title="RequestedAmount" disabled="disabled" />
                            <small id="txtReqAmountWords" class="form-text text-muted"></small>
                        </div>

                        <div class="col-md-3" id="divTDSAmount">
                            <label for="fundcat">TDS Amount</label>
                            <input type="text" class="form-control" readonly="readonly" style="color:red" id="txt_tds_amnt" title="RequestedAmount" disabled="disabled" />
                            <small id="txtTDSReqAmountWords" class="form-text text-muted"></small>
                        </div>

                        <div class="col-md-3" id="divNetAmount">
                            <label for="fundcat">Net Amount</label>
                            <input type="text" class="form-control" readonly="readonly" style="color:red" id="txt_net_amnt" title="RequestedAmount" disabled="disabled" />
                            <small id="txtNetAmountWords" class="form-text text-muted"></small>
                        </div>

                        <div class="col-md-3" id="divpayAmnt">

                            <label for="fundcat">Payment Amount</label>
                            <input type="text" class="form-control" style="color:red" id="txtTotalAmount" title="TotalAmount" disabled="disabled" />
                            <small id="TotalAmountWords" class="form-text text-muted"></small>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="fundcat">Payment Type<span class="text-danger">*</span></label>
                                    <select class="custom-select form-control" id="ddlPaymentType" name="ddlPaymentType">
                                        <option value="0">Choose Payment Type</option>
                                        <option id="automaticid" value="automatic">Automatic</option>
                                        <option value="manual">Manual</option>
                                    </select>
                                </div>
                            </div>
                        </div>



