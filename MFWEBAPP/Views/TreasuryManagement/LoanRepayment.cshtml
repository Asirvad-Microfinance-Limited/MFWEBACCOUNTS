                    </div>

                </form>

            </div>
            <div class="card-footer">
                <div class="text-end">
                    <input id="btnConf" type="button" style="background-color:forestgreen;color:white; width:70px; height:30px;  margin-left:1000px;" value="Confirm" class="btn btn-primary" />
                    <input id="btnExit" type="button" style="background-color:red; color:white;width:70px;height:30px;" value="Exit" class="btn btn-danger" />
                </div>
