                            <div class="form-group">
                                <label class="control-label mb-1">Payment Bank</label>
                                <select class="custom-select form-control" id="ddlPaymentBank" style="width:100%" name="ddlPaymentBank"> <option value="0"> ------------ CHOOSE BANK ------------ </option> </select>
