@{
    ViewData["Title"] = "PrincipalInterestEntry";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}

<div class="">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <strong class="card-title">ACCOUNTING ENTRY</strong>
            </div>
            <div class="card-body card-block">
                <form name=" " id=" " method="post" class="form-horizontal">
                    <div class="row">
                        <div class="col-md-3" >
                            <div class="form-group" id="acctnumber">
                                <label for="fundsubcat">Account Number<span class="text-danger">*</span></label>
                                <select class="custom-select form-control" id="ddlaccno"   name="accountnumber">
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3" style="display:none" id="subaccload">
                            <div class="form-group">
                                <label for="fundsubcat">Sub Account No<span class="text-danger"></span></label>
                                <select class="custom-select form-control" id="ddlsubacc"  name="subaccountno" 
                                >
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3" style="display:none" id="subidload">
                            <div class="form-group">
                                <label for="fundsubcat">Sub ID<span class="text-danger"></span></label>
                                <select class="custom-select form-control" id="ddlsubid" name="Subid" >
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3" id="divdiscription">
                        <div class="form-group" >
                            <label for="description">Description<span class="text-danger">*</span></label>
                            <input type="text" class="form-control"  id="description" title="Description" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group" id="divamt">
                                <label for="amount">Amount<span class="text-danger">*</span></label>
                                <input type="text" class="form-control" oninput="this.value = this.value.replace(/[^0-9.]/g, '');" id="amount" title="Amount" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group" id="divdebitorcredit">
                                <label for="fundsubcat">Select Type<span class="text-danger">*</span></label>
                                <select class="custom-select form-control" id="ddltype" name="Type" >
                                    <option value="0">Debit</option>
                                    <option value="1">Credit</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3 my-4">
                            <div class="form-group">
                                <input id="btnAdd" type="button" value="ADD" class="btn btn-success"  />
                            </div>
                        </div>
                    </div>
