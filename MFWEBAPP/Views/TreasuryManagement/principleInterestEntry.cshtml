                                <label for="debit">Debit<span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="txtdebit" title="Debit" readonly />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="credit">Credit<span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="txtcredit" title="Credit" readonly />
