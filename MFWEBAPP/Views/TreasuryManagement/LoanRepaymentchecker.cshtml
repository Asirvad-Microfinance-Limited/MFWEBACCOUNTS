            <div class="row mb-2">
                <div class="col-md-12">
                    <div class="form-group">
                        <label for="agreemntfrom">Do You Transfer The Cash ?<span class="text-danger">*</span></label><br/>
                        <input type="radio" id="radYes" name="radcheck" class="custom-control-input" style="cursor:pointer" >
                        <label class="custom-control-label" for="radYes" style="cursor:pointer">Yes</label>
                        &nbsp;
