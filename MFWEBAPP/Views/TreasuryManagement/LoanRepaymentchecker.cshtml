@{
    ViewData["Title"] = "LoanRepaymentchecker";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}

<div class="card">
    <div class="col-lg-12">
        <div class="card-header">
            <strong class="card-title">Payment Of Other Charges</strong>
        </div>
        <div class="card-body">
            <form name=" " id=" " method="post" class="form-horizontal">
                <div class="row mb-2">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="fundcat">Select Financial Institution<span class="text-danger">*</span></label>
                            <select class="custom-select form-control" id="ddl_fI" name="Select Finanacial Institution"></select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group" id="sclfnd">
                            <label for="fundcat">Select Fund<span class="text-danger">*</span></label>
                            <select class="custom-select form-control" id="ddl_Loan" name="Select Fund"> </select>
                        </div>
                    </div>
                </div>
                <div class="row mb-2" id="ShowtblDiv" style="display:none;">

                    <div class="col-md-12">
                        <div class="form-group">
                            <h4 class=" "><strong>Fund Details :</strong></h4>
                            <div class="table-responsive">
                                <table class="table" id="tableShowLoans">
                                    <thead class="bg-inverse text-white">
                                        <tr>
                                        </tr>
                                    </thead>
                                    <tbody class="border border-dark"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>


                <div class="card" id="maincard" style="display:none;margin-top: 20px;">
                    <div class="card-body" style="background-color:#fff !important; ">
                        <div class="table-responsive">
                            <div align="center" id="divdespatch" name="divdespatch" style="position: relative;min-height:100px;overflow: auto;display: block;">
                                <table class="table" id="tbldespatch">
                                    <thead>
                                        <tr>
                                            @* <th class="VCol" style="text-align:left;">#</th> *@
                                            <th class="VCol" style="text-align:left;">Fund_Type</th>
                                            <th class="VCol" style="text-align:left;">Fund</th>
                                            <th class="VCol" style="text-align:left;">FI_Type</th>
                                            <th class="VCol" style="text-align:left;">FI_Name</th>
                                            <th class="VCol" style="text-align:left;">Entered Date</th>
                                            <th class="VCol" style="text-align:left;">From Date</th>
                                            <th class="VCol" style="text-align:left;">To Date</th>
                                            <th class="VCol" style="text-align:left;">Entered By</th>
                                            <th class="VCol" style="text-align:left;">Amount</th>
                                            <th class="VCol" style="text-align:left;">ROI</th>
                                            <th class="VCol" style="text-align:left;">Personal Guarantee</th>


                                            <th class="VCol" style="text-align:center;">&nbsp;</th>
                                        </tr>
                                    </thead>
                                    <tbody id="Fidatatabl"></tbody>
                                </table>

                            </div>
                        </div>
                    </div>
                </div>



            </form>

            @* <div class="row mb-2">
                <div class="col-md-12">
                    <div class="form-group">
                        <div class="col-md-6">
                            <div class="form-group">
                                <input type="radio" id="radigst" name="radproc" class="custom-control-input">
                                <label class="custom-control-label" for="radigst">Other Charges With IGST</label>
                                &nbsp;
                                <input type="radio" id="radsgst" name="radproc" class="custom-control-input">
                                <label class="custom-control-label" for="radsgst">Other Charges With SGST & CGST</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div> *@



            <div class="row">
                <div class="col-md-12">
                    <div class="row form-group">
                        <div class="form-group col-lg-4 col-md-4 col-sm-4 col-xs-4">

                            <div class="custom-control custom-radio" id="bs_datepicker_container1 ">
                                <div>
                                    <input type="radio" id="radigst" name="radproc" value="louie" />
                                    <label for="louie">Processing Fee With IGST</label>
                                </div>
                            </div>
                            <div class="custom-control custom-radio" id="bs_datepicker_container1">
                                <div>
                                    <input type="radio" id="radsgst" name="radproc" value="louie" />
                                    <label for="louie">Processing Fee With SGST & CGST</label>
                                </div>
                            </div>

                        </div>


                    </div><br />
                </div>
            </div>

