@{
    ViewData["Title"] = "IntAccrualAuto";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}



<div class="row">
    <div class="col-12">
        <div class="card ">
            <div class="card-header">
                <strong class="card-title">INTEREST ACCRUAL AUTOMATION</strong>
            </div>
            
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                            <div class="text-center">

                              
                                    @*class="btn btn-success"*@
                              
                                <button type="button" id="btn_Excel" name="btnexport" class="btnsmall btn-danger" style="margin-left:2%;"> <i class="fa  fa-file-excel-o" style="font-size:20px;margin-top: 4px;"></i></button>
                                
                               @*  <input type="button" class="btn btn-success" id="btn_Excel" value="Export to Excel" onclick="btn_Excel_Click" /> *@
                            </div>
                        </div>
                    </div>
                </div>
        </div>


            <div class="card" id="maincard" style="display:none;margin-top: 20px;">
                <div class="card-body" style="background-color:#fff !important; ">
                    <div class="table-responsive">
                        <div align="center" id="divdespatch" name="divdespatch" style="position: relative;min-height:100px;overflow: auto;display: block;">
                            <table class="table" id="tbldespatch">
                                <thead>
                                    <tr>
                                        @* <th class="VCol" style="text-align:left;">#</th> *@
                                        <th class="VCol" style="text-align:left;">LOAN_ID</th>
                                        <th class="VCol" style="text-align:left;">PROJECT_CODE	</th>
                                        <th class="VCol" style="text-align:left;">FINANCE_COST_MAIN_ACC	</th>
                                        <th class="VCol" style="text-align:left;">FINANCE_COST_SUB_ACC</th>
                                        <th class="VCol" style="text-align:left;">INT_MAIN_ACC</th>
                                        <th class="VCol" style="text-align:left;">INT_SUB_ACC_NO</th>
                                        <th class="VCol" style="text-align:left;">CONTRA_ID	</th>
                                        <th class="VCol" style="text-align:left;">INTEREST_ACCRUAL</th>
                                        <th class="VCol" style="text-align:left;">ENTRY_DATE</th>
                                        <th class="VCol" style="text-align:left;">REVERSAL_DATE	</th>
                                        <th class="VCol" style="text-align:left;">LOAN_OUTSTANDING</th>
                                        <th class="VCol" style="text-align:left;">INTEREST_RATE	</th>
                                        <th class="VCol" style="text-align:left;">LAST_INTR_PAY_DT</th>
                                       

                                        <th class="VCol" style="text-align:center;">&nbsp;</th>
                                    </tr>
                                </thead>
                                <tbody id="Fidatatabl"></tbody>
                            </table>

                        </div>
                    </div>
                </div>
            </div>


            <div class="card-footer text-end">
                <input id="btnConf" type="button" value="Confirm" class="btn btn-primary" data-toggle="modal" data-backdrop="false" />

                <input id="btnExit" type="button" value="Exit" class="btn btn-danger"  data-toggle="modal" data-backdrop="false" />
            </div>
        </div>
    </div>
        

</div>

  
<input id="hdUserId" type="hidden" runat="server" />

@section Scripts {
    <script src="~/clientapp/treasurymanagement/intaccrualauto.js"></script>
    <script src="//ajax.googleapis.com/ajax/libs/jquery/1.11.1/jquery.min.js"></script>
    <script src="src/jquery.table2excel.js"></script>
    
}