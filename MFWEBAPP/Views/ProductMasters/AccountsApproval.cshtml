
@{
    ViewData["Title"] = "AccountsApproval";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}

<div class="">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <strong class="card-title">Accounts Approval</strong>
            </div>
            <div class="card-body card-block">
                <form name="frmAccountsApproval" id="frmAccountsApproval" method="post" class="form-horizontal">

                    <div class="row form-group">
                        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                            <label for="cc-payment" class="control-label mb-1">Payment Request<b style="color:red">*</b></label>
                            <select name="ddlPayType" id="ddlPayType" class="form-control">
                                <option value="0"> ------------ Select ------------ </option>
                            </select>
                            <label id="ddlPayType-error" class="error" for="ddlPayType" style="display:block"></label>
                        </div>
                        <div class="col-lg-2 col-md-6 col-sm-12 col-xs-12">
                            <br />
                            <button type="button" class="btn btn-link" id="viewinvoice">View Receipt</button>

                        </div>
                    </div>

                    <div class="modal fade" id="ImageModel" tabindex="-1" role="dialog" aria-labelledby="Modal1" aria-hidden="true" data-backdrop="static" data-keyboard="false">
                        <div class="modal-dialog modal-lg" role="document">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="largeModalLabel">Image</h5>
                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="FnClose()">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <div class="modal-body">
                                    <div class="row">
                                        <div class="col-md-12" id="ImageDiv" style="text-align:center;">
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <div align="center" class="col-lg-12">
                                        <button type="button" id="rtt" data-dismiss="modal" aria-label="Close" class="btn btn-primary" onclick="FnClose()"><i class="fa fa-close"></i>&nbsp;Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row form-group">
                        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label class="control-label mb-1">Payment Type</label>
                                <input type="text" id="payType" name="payType" placeholder="" class="form-control" maxlength="15" readonly>
                                <label id="payType-error" class="error" for="payType" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label class="control-label mb-1">Vendor Name</label>
                                <input type="text" id="vendorName" name="vendorName" placeholder="" class="form-control" maxlength="15" readonly>
                                <label id="vendorName-error" class="error" for="vendorName" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label class="control-label mb-1">GSTN</label>
                                <input type="text" id="gstin" name="gstin" placeholder="" class="form-control" maxlength="15" readonly>
                                <label id="gstin-error" class="error" for="gstin" style="display:block"></label>
                            </div>
                        </div>
                    </div>
                    <div class="row form-group">
                        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label class="control-label mb-1">Amount Limit</label>
                                <input type="text" id="amtLimit" name="amtLimit" placeholder="" class="form-control" maxlength="15" readonly>
                                <label id="amtLimit-error" class="error" for="amtLimit" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label class="control-label mb-1">Requested Amount</label>
                                <input type="text" id="reqAmt" name="reqAmt" placeholder="" class="form-control" maxlength="15" readonly>
                                <label id="reqAmt-error" class="error" for="reqAmt" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label class="control-label mb-1">Excess Amount</label>
                                <input type="text" id="excessAmt" name="excessAmt" placeholder="" class="form-control" maxlength="15" readonly>
                                <label id="excessAmt-error" class="error" for="excessAmt" style="display:block"></label>
                            </div>
                        </div>
                    </div>
                    <div class="row form-group">
                        <div class="col-lg-12 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label class="control-label mb-1">Remarks</label><b style="color:red">*</b>
                                <input type="text" id="dmremarks" name="dmremarks" placeholder="" class="form-control text-uppercase" maxlength="150" oninput="this.value = this.value.replace(/[^a-zA-Z0-9., ]/g, '');">
                                <label id="dmremarks-error" class="error" for="dmremarks" style="display:block"></label>
                            </div>
                        </div>
                    </div>
                    <div class="text-right">
                        <button type="button" class="btn btn-success" id="submit">Approve</button>
                        <button type="button" class="btn btn-danger" id="reject">Reject</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts{

    <script src="~/ClientApp/PaymentAtBranch/AccountsApproval.js"></script>

}