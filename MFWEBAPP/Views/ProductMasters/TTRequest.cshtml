
@{
    ViewData["Title"] = "TTRequest";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}
<div id="Loader" class="page-loader-wrapper">
    <div class="loader">
        <div class="preloader">
            <div class="spinner-layer pl-blue-grey">
                <div class="circle-clipper left">
                    <div class="circle"></div>
                </div>
                <div class="circle-clipper right">
                    <div class="circle"></div>
                </div>
            </div>
        </div>
        <p style="color:#dbb714;font-family:'Myanmar Text'">Please Wait...</p>
    </div>
</div>


<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header"><strong>TT Request </strong></div>
            <div class="card-body card-block" style="background-color:#fff">
                <div class="row">
                    
                       <div class="col col-md-2 col-sm-6 col-xs-12" style="text-align: left;">
                        <label for="street" class="form-control-label">Branch Name<b style="color: red;">*</b></label>
                        <input type="text" id="BranchName" name="BranchName" placeholder="Branch Name" class="form-control" disabled>
                       </div>
                        <div class="col col-md-3 col-sm-6 col-xs-12" style="text-align: left;">
                        <label for="street" class="form-control-label">Bank Name<b style="color: red;">*</b></label>
                        <input type="text" id="BankName" name="BankName" placeholder="Bank Name" class="form-control" disabled>
                        </div>

                        <div class="col-md-2" style="text-align: left;">
                        <label for="street" class="form-control-label">Amount In Need<b style="color: red;">*</b></label>
                        <input type="text" id="amount" name="amount" placeholder="Amount" class="form-control" oninput="this.value = this.value.replace(/[^0-9]/g, '').replace(/(\..*)\./g, '$1')" maxlength="12" >

                         </div>
                        <div class="col col-md-4 col-sm-6 col-xs-12" style="text-align: left;">
                        <label for="street" class="form-control-label">Remark<b style="color: red;">*</b></label>
                        <input type="text" id="remark" name="remark" placeholder="Reason" class="form-control" maxlength="100">

                        </div>

                </div>
                        <div class="row" style="margin-left:265px;">
                         <button type="button" style="margin-left:800px;margin-top:20px" class="btn btn-success" id="BtnConfirm">Confirm</button>
                         <button type="button" style="margin-left:20px;margin-top:20px" class="btn btn-danger" id="btn_exit">Clear</button>

                       </div>

                       <div class="row">
                         <div class="col-lg-6 col-md-6 col-sm-12 col-xl-12 no-padding">
                            <div class="card-body" style="background-color:#fff !important;">

                                <div class="table-responsive">
                                    <div align="center" id="divloanDetails" name="divloanDetails">
                                    </div>
                                </div>
                            </div>
                         </div>
                       </div>
            </div>
        </div>
    </div>
</div>

@section Scripts{

    @*<script src="~/ClientApp/TTRequest/TTRequest.js"></script>*@
    <script src="~/ClientApp/PaymentAtBranch/TTRequest.js"></script>

}
