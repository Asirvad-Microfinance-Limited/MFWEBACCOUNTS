                            <div class="form-group">
                                <label class="control-label mb-1">Subject:</label><b style="color:red">*</b>
                                <textarea id="dmSubject" name="dmSubject" rows="4" cols="50" class="form-control " maxlength="150" oninput="this.value = this.value.replace(/[^a-zA-Z0-9., ]/g, '');"></textarea>

                                @*<input type="text" id="dmremarks" name="dmremarks" placeholder="" class="form-control text-uppercase" maxlength="150" oninput="this.value = this.value.replace(/[^a-zA-Z0-9., ]/g, '');">*@
                                <label id="dmremarks-error" class="error" for="dmremarks" style="display:block"></label>
                            </div>
                        </div>

                    </div>



                    <div class="row form-group">
                        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label class="control-label mb-1">Upload Document:</label>
                                @*<b style="color:red">*&nbsp;&nbsp;&nbsp;</b><span style="color:green;display:none" id="tick"><i class="fa fa-check fa-lg" aria-hidden="true"></i></span>
                                <span style="color:red" id="close"><i class="fa fa-close fa-lg" aria-hidden="true"></i></span><br />*@
                                @*<h4 class="card-title">Upload Document: </h4>*@
                                

                                        <div class="col-lg-9 col-md-6 col-sm-12 col-xs-12">
