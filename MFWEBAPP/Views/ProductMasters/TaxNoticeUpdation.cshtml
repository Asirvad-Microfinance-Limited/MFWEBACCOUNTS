                                <div class="custom-control custom-radio">
                                    <input type="radio" id="radind" name="Tax" class="custom-control-input" value="INDIRECT TAX" />
                                    <label class="custom-control-label" for="radind">INDIRECT TAX</label>
                                </div>
                                <div class="custom-control custom-radio">
                                    <input type="radio" id="radoth" name="Tax" class="custom-control-input" value="OTHERS" />
                                    <label class="custom-control-label" for="radoth">OTHERS</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-3" id="txt_type" style="display:none">
