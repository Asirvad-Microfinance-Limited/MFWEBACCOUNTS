                                <label for="datepicker" class=" form-control-label mb-1">Previous Year <b style="color:red">*</b></label>
                                <input class="form-control datepicker " id="txtpreyr" name="etoDate" placeholder="YYYY" type="text" readonly="readonly" />
                                <label id="dtFromDate-error" class="error" for="txtpreyr" style="display:block"></label>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-3" id="bs_datepicker_container22">
                            <div class="form-group">
                                <label for="datepicker" class=" form-control-label mb-1">Assessment Year <b style="color:red">*</b></label>
                                <input class="form-control datepicker " id="txtassesmtyr" name="etoDate" placeholder="YYYY" type="text" readonly="readonly" />
