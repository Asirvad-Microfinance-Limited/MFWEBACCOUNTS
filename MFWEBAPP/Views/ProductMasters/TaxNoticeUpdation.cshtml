                                <label id="dtFromDate-error" class="error" for="dtFromDate" @*style="display:block" *@></label>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-3" id="bs_datepicker_container2">
                            <div class="form-group">
                                <label for="datepicker" class=" form-control-label mb-1">To Date<b style="color:red">*</b></label>
                                <input class="form-control datepicker " id="etoDate" name="etoDate" placeholder="DD-MM-YYYY" type="text" readonly="readonly" />
                                <label id="dtFromDate-error" class="error" for="etoDate" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-3" id="bs_datepicker_container11">
