                                <label class="control-label mb-1">Notice No:</label><b style="color:red">*</b>
                                <input type="text" id="txtnoticeno" name="dmremarks" placeholder="" class="form-control " maxlength="100" >
                                <label id="dmremarks-error" class="error" for="dmremarks" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-3">
                            <div class="form-group">
                                <label class="control-label mb-1">Amount Involved</label>
                                <input type="text" id="txtamontinvolved" name="txtamontinvolved"   class="form-control text-uppercase" maxlength="10" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" />
                                <label id="dmremarks-error" class="error" for="dmremarks" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-3" id=" ddlrec">
