                            <select name="ddldocsbmted" id="ddldocsbmted" class="form-control">
                                <option value="0"> ------------ Select Type------------ </option>
                                <option value="Post">Post </option>
                                <option value="IT Portal">IT Portal </option>
                                <option value="other">other </option>
                            </select>
