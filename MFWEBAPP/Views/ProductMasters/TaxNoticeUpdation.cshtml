                                <textarea id="dmremarks" name="dmremarks" rows="4" cols="50" class="form-control " maxlength="150" oninput="this.value = this.value.replace(/[^a-zA-Z0-9., ]/g, '');"></textarea>

                                <label id="dmremarks-error" class="error" for="dmremarks" style="display:block"></label>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-3">
                            <div class="form-group">
                                <label class="control-label mb-1">Specify Reason:</label><b style="color:red">*</b>
                                @*<input type="text" id="dmreason" name="dmreason" placeholder="" class="form-control text-uppercase" maxlength="150" oninput="this.value = this.value.replace(/[^a-zA-Z0-9., ]/g, '');">*@
                                <textarea id="dmreason" name="dmreason" rows="4" cols="50" class="form-control " maxlength="150" oninput="this.value = this.value.replace(/[^a-zA-Z0-9., ]/g, '');"></textarea>

                                <label id="dmremarks-error" class="error" for="dmremarks" style="display:block"></label>
                            </div>
