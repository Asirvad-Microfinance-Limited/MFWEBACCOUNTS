
@{
    ViewData["Title"] = "Branch Entry Approval";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}

<div class="">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <strong class="card-title">Branch Entry Approval</strong>
            </div>
            <div class="card-body card-block">
                <form name="frmBranchentryapproval" id="frmBranchentryapproval" method="post" class="form-horizontal">
                    <div class="row form-group">
                        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                            <label for="cc-ddlRequested" class="control-label mb-1">Requested ID<b style="color:red">*</b></label>
                            <select name="ddlRequested" id="ddlRequested" class="form-control">
                                <option value="0"> ------------ Select ------------ </option>

                            </select>
                            <label id="ddlRequested-error" class="error" for="ddlRequested" style="display:block"></label>
                        </div>

                    </div>
                    <div class="card" id="maincard" style="display:none;margin-top: 20px;">
                        <div class="card-body" style="background-color:#fff !important; ">
                            <div class="table-responsive">
                                <div align="center" id="divdespatch" name="divdespatch" style="position: relative;min-height:100px;overflow: auto;display: block;">
                                    <table class="table" id="tbldespatch">
                                        <thead>
                                            <tr>
                                                <th class="VCol" style="text-align:left;">#</th>
                                                <th class="VCol" style="text-align:left;">BRANCH</th>
                                                <th class="VCol" style="text-align:left;">MAIN ACCOUNT</th>
                                                <th class="VCol" style="text-align:left;">SUB ACCOUNT</th>
                                                <th class="VCol" style="text-align:left;">DESCRIPTION</th>
                                                <th class="VCol" style="text-align:right;">DEBIT</th>
                                                <th class="VCol" style="text-align:right;">CREDIT</th>
                                            </tr>
                                        </thead>
                                        <tbody id="paymenttabl"></tbody>
                                    </table>

                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="confirm" class="text-right" style="display:none;">
                        <button type="button" class="btn btn-success" id="submit">Confirm</button>&nbsp;&nbsp;&nbsp;
                        <button type="button" class="btn btn-danger" id="reject">Reject</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts{

    <script src="~/ClientApp/PaymentAtBranch/branchEntryApproval.js"></script>
}