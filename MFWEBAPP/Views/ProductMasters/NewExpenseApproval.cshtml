@{
    ViewData["Title"] = "NewExpenseApproval";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}
<div class="col-lg-12">
    <div class="card">
        <div class="card-header">
            <strong class="card-title">New Expense Approval</strong>
        </div>
        <div class="card" id="maincard" style="background-color:#fff !important;">
            @* <div class="text-center" style="margin: 20px;"> *@
            @*     <div class=""> *@
            @*         <input type="text" style="width:600px; display:inline-block;" id="searchBox" class="form-control" placeholder="Search Branch..."> *@
            @*         <button type="button" id="searchButton" class="btn btn-primary" style="display:inline-block;">Search</button> *@
            @*     </div> *@
            @* </div> *@
            <div class="text-center" style="margin: 20px;"> 
                 <div class="" >
                    <label class="control-label mb-1">Choose Type: </label>
                    <select name="type_select" style="width:400px; display:inline-block;" id="type_select" class="form-control">
                        <option value="0"> ------------ Select ------------ </option>
                        <option value="1"> NORMAL BRANCH </option>
                        <option value="2"> GL BRANCH</option>
                    </select>
                </div>
            </div>
            <div class="card-body" id="expense_tbl" style="background-color:#fff !important;">
        <div class="table-responsive">
            <div align="center" id="divdespatch" name="divdespatch" style="position: relative;min-height:100px;overflow: auto;display: block;">
                <table class="table" id="tbldespatch">
                    <thead>
                        <tr>
                            <th class="VCol" style="text-align:left;">SI.NO</th>
                            <th class="VCol" style="text-align:left;">EXPENSE</th>
                            <th class="VCol" style="text-align:center;">NEW/RESUBMITTED</th>
                           <th class="VCol" style="text-align:center;">VIEW</th> 
                        </tr>
                    </thead>
                    <tbody id="newexpense"></tbody>
                </table>
            </div>
        </div>
    </div>

            @* card showing details *@
            <div class="modal fade" id="moreDetailsModal" tabindex="-1" role="dialog" aria-labelledby="more" aria-hidden="true" data-backdrop="static" data-keyboard="false">
                <div class="modal-dialog modal-md" role="document">
                    <div class="modal-content" style="height:600px; width:670px">
                        <div class="modal-header">
                            <h5 class="modal-title" id="mediumModalLabel">Bank Details</h5>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                       
                        <div>
                            <div class="form-group" style="margin-left:20px">
                                <label for="cc-payment" class="control-label mb-1">Expense<b style="color:red">*</b></label>
                                <input type="hidden" id="typeid">
                                <input type="text" id="exp" style="width:630px;" name="exp" placeholder="" class="form-control" readonly oninput="this.value" ;="">
                            </div>
                        </div>

                        <div>
                            <div class="form-group" style="margin-left:20px">
                                <label for="cc-payment" class="control-label mb-1">PERIOD<b style="color:red">*</b></label>
                                <input type="text" id="period" style="width:200px;" name="period" placeholder="" readonly class="form-control" oninput="this.value;">
                            </div>
                        </div>
                        <div>
                            <div class="form-group"  style="margin-left:240px; margin-top:-60px;">
                                <label for="cc-payment" class="control-label mb-1">CEILING LIMIT <b style="color:red">*</b></label>
                                <input class="form-control" style="width:200px;" id="lmt" name="lmt" readonly placeholder="" type="text">
                            </div>
                        </div>
                        <div>
                            <div class="form-group"  style="margin-left:450px; margin-top:-60px;">
                                <label for="cc-payment" class="control-label mb-1">BRANCH HEAD LIMIT <b style="color:red">*</b></label>
                                <input class="form-control" style="width:200px;" id="bhlmt" readonly name="bhlmt" placeholder="" type="text">
                            </div>
                        </div>

                        <div>
                            <div class="form-group" style="margin-left:20px">
                                <label for="cc-payment" class="control-label mb-1">AREA HEAD LIMIT<b style="color:red">*</b></label>
                                <input type="text" id="ahlmt" style="width:200px;" name="ahlmt" readonly placeholder="" class="form-control" oninput="this.value;">
                            </div>
                        </div>
                        <div>
                            <div class="form-group" id="bs_datepicker_container2" style="margin-left:240px; margin-top:-60px;">
                                <label for="cc-payment" class="control-label mb-1">REGIONAL MANAGER LIMIT <b style="color:red">*</b></label>
                                <input class="form-control" style="width:200px;" id="rmlmt" readonly name="rmlmt" placeholder="" type="text">
                            </div>
                        </div>
                        <div>
                            <div class="form-group" id="bs_datepicker_container2" style="margin-left:450px; margin-top:-60px;">
                                <label for="cc-payment" class="control-label mb-1">ZONAL MANAGER LIMIT <b style="color:red">*</b></label>
                                <input class="form-control" style="width:200px;" id="zmlmt" readonly name="zmlmt" placeholder="" type="text">
                            </div>
                        </div>

                        <div>
                            <div class="form-group" style="margin-left:20px">
                                <label for="cc-payment" class="control-label mb-1">OPERATION HEAD LIMIT<b style="color:red">*</b></label>
                                <input type="text" id="ohlmt" style="width:200px;" name="ohlmt" readonly placeholder="" class="form-control" oninput="this.value;">
                            </div>
                        </div>
                        <div>
                            <div class="form-group"  style="margin-left:240px; margin-top:-60px;">
                                <label for="cc-payment" class="control-label mb-1">INFRA HEAD LIMIT <b style="color:red">*</b></label>
                                <input class="form-control" style="width:200px;" id="ihlmt" readonly name="ihlmt" placeholder="" type="text">
                            </div>
                        </div>
                        <div>
                            <div class="form-group"  style="margin-left:450px; margin-top:-60px;">
                                <label for="cc-payment" class="control-label mb-1">CTO LIMIT <b style="color:red">*</b></label>
                                <input class="form-control" style="width:200px;" id="ctolmt" readonly name="ctolmt" placeholder="" type="text">
                            </div>
                        </div>

                        <div>
                            <div class="form-group" style="margin-left:20px">
                                <label for="cc-payment" class="control-label mb-1">ACCOUNT NUMBER<b style="color:red">*</b></label>
                                <input type="text" id="acc" style="width:200px;" name="acc" readonly placeholder="" class="form-control" oninput="this.value;">
                            </div>
                        </div>
                        <div>
                            <div class="form-group"  style="margin-left:240px; margin-top:-60px;">
                                <label for="cc-payment" class="control-label mb-1">SUB ACCOUNT NUMBER<b style="color:red">*</b></label>
                                <input class="form-control" style="width:200px;" id="subacc" readonly name="subacc" placeholder="" type="text">
                            </div>
                        </div>
                        <div>
                            <div class="form-group"  style="margin-left:20px; margin-top:5px;">
                                <label for="cc-payment" class="control-label mb-1">REMARK<b style="color:red">*</b></label>
                                <input class="form-control" style="width:630px;" id="remark"  name="remark" placeholder="" type="text">
                            </div>
                        </div>
                        
                       
                        <div class="modal-footer">
                            <button type="button" class="btn btn-success" id="btn_approve" margin-top:5px;="" width:150px;"="" data-dismiss="modal">Approve</button>
                            <button type="button" class="btn btn-danger" id="btn_reject" margin-top:5px;="" width:150px;"="" data-dismiss="modal">Reject</button>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>








@section Scripts {
	<script src="~/clientapp/paymentatbranch/newexpenseapproval.js"></script>
}