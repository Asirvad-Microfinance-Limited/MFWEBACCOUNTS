
@{
    ViewData["Title"] = "CourierUpdation";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}

<div class="">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <strong class="card-title">Courier Updation</strong>
            </div>
            <div class="card-body card-block">
                <form name="frmcourierupdation" id="frmcourierupdation" method="post" class="form-horizontal">
                    <div class="row form-group">
                        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                            <label for="cc-ddldept" class="control-label mb-1">Outward Number<b style="color:red">*</b></label>
                            <select name="ddlOutWard" id="ddlOutWard" class="form-control">
                                <option value="0"> ------------ Select ------------ </option>

                            </select>
                            <label id="ddlOutWard-error" class="error" for="ddlOutWard" style="display:block"></label>
                        </div>
                    </div>
                    <div class="card" id="maincard" style="display:none;margin-top: 20px;">
                        <div class="card-body" style="background-color:#fff !important; ">
                            <div class="table-responsive">
                                <div align="center" id="divdespatch" name="divdespatch" style="position: relative;min-height:100px;overflow: auto;display: block;">
                                    <table class="table" id="tbldespatch">
                                        <thead>
                                            <tr>
                                                <th class="VCol" style="text-align:left;">PRID</th>
                                                <th class="VCol" style="text-align:left;">PAYMENT TYPE</th>
                                                <th class="VCol" style="text-align:left;">AMOUNT</th>
                                                <th class="VCol" style="text-align:left;">BILL NUMBER</th>
                                                <th class="VCol" style="text-align:left;">BILL DATE</th>
                                                <th class="VCol" style="text-align:center;">PERIOD OF PAYMENT</th>
                                            </tr>
                                        </thead>
                                        <tbody id="paymenttabl"></tbody>
                                    </table>

                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="others" style="display:none;">
                        <div class="row form-group">
                            <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                                <div class="form-group">
                                    <label class="control-label mb-1">Agency Name<b style="color:red">*</b></label>
                                    <input type="text" id="agencyName" name="agencyName" placeholder="" class="form-control text-uppercase" maxlength="30" oninput="this.value = this.value.replace(/[^0-9A-Za-z ]/g, '').replace(/(\..*)\./g, '$1');">
                                    <label id="agencyName-error" class="error" for="agencyName" style="display:block"></label>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                                <div class="form-group">
                                    <label class="control-label mb-1">No Of Bills<b style="color:red">*</b></label>
                                    <input type="text" id="nobills" name="nobills" placeholder="" class="form-control" maxlength="2" readonly>
                                    <label id="nobills-error" class="error" for="nobills" style="display:block"></label>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                                <div class="form-group">
                                    <label class="control-label mb-1">Challan Number<b style="color:red">*</b></label>
                                    <input type="text" id="challanno" name="challanno" placeholder="" class="form-control text-uppercase" maxlength="12" oninput="this.value = this.value.replace(/[^0-9A-Za-z]/g, '').replace(/(\..*)\./g, '$1');">
                                    <label id="challanno-error" class="error" for="challanno" style="display:block"></label>
                                </div>
                            </div>

                        </div>
                        <div class="row form-group">
                            <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                                <div class="form-group">
                                    <label class="control-label mb-1">Total Weight(in Gram)<b style="color:red">*</b></label>
                                    <input type="text" id="totWeight" name="totWeight" placeholder="" class="form-control" maxlength="6" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');">
                                    <label id="totWeight-error" class="error" for="totWeight" style="display:block"></label>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                                <div class="form-group">
                                    <label class="control-label mb-1">Send Date<b style="color:red">*</b></label>
                                    <input type="text" id="sendDate" name="sendDate" placeholder="" class="form-control" readonly>
                                    <label id="sendDate-error" class="error" for="sendDate" style="display:block"></label>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                                <div class="form-group">
                                    <label class="control-label mb-1">Amount<b style="color:red">*</b></label>
                                    <input type="text" id="Amount" name="Amount" placeholder="" class="form-control" maxlength="6" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');">
                                    <label id="Amount-error" class="error" for="Amount" style="display:block"></label>
                                </div>
                            </div>
                        </div>

                        <div class="row form-group">
                            <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12">
                                <div class="form-group">
                                    <label class="control-label mb-1">Attach Courier Challan</label><b style="color:red">*&nbsp;&nbsp;&nbsp;</b><span style="color:green;display:none" id="tick"><i class="fa fa-check fa-lg" aria-hidden="true"></i></span><span style="color:red" id="close"><i class="fa fa-close fa-lg" aria-hidden="true"></i></span><br />
                                    <button type="button" class="btn btn-link" id="billupd">Capture</button>
                                    <label id="billupd-error" class="error" for="billupd" style="display:block"></label>
                                </div>
                            </div>

                           



                           
                        </div>
                        <div id="camsection" class="modal">
                            <div class=" modal-content">
                                <div class="row">
                                    <div class="col-md-12">
                                        <span id="closeCam" class="close">&times;</span>
                                    </div>
                                </div>
                                <div class="row">
                                    &nbsp;
                                </div>
                                <div class="row">
                                    <div class="col-md-5">
                                        <div id="camera">

                                        </div>
                                    </div>

                                    <div id="click" class="col-md-2" style="text-align: center;padding-top: 110px;">
                                        <button type="button" id="ClickmeBtn" class="btn btn-md btn-success" value="Click Me">Click Me</button>
                                    </div>

                                    <div class="col-md-5">
                                        <div id="viewUploadedImages" name="viewUploadedImages" style="position: relative;max-height: 300px;max-width: 100%;overflow: hidden;display: block;">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="confirm" style="display:none;" class="text-right">
                        <button type="button" class="btn btn-success" id="submit">Confirm</button>
                        
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts{

    <script src="~/ClientApp/PaymentAtBranch/InvoiceWebcamFile.js"></script>
    <script src="~/ClientApp/PaymentAtBranch/CourierUpdation.js"></script>

}
