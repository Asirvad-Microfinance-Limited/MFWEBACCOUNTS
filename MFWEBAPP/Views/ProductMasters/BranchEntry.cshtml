
@{
    ViewData["Title"] = "Branch Entry";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}



<style type="text/css">
    .table tbody tr:hover {
        background-color: #f5f5f5 !important;
    }

    table thead th {
        color: #292b35;
        background-color: #f2f0e8;
    }

    table, th {
        border: 2px solid #fff !important;
    }

    .hide {
        display: none !important;
    }

    .card-body {
        overflow: auto;
    }
</style>

<div class="">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <strong class="card-title">Branch Entry</strong>
            </div>
            <div class="card-body card-block">

                <form name="frmPaymetAtBranch" id="frmPaymetAtBranch" method="post" class="form-horizontal">

                    <div class="row form-group">
                        <div id="typelength" class="col-lg-4">
                            <label for="cc-payment" class="control-label mb-1">Payment Type<b style="color:red">*</b></label>
                            <select name="ddlPayType" id="ddlPayType" class="form-control">
                                <option value="0"> ------------ Select ------------ </option>

                            </select>
                            <label id="ddlPayType-error" class="error" for="ddlPayType" style="display:block"></label>

                        </div>
                        <div class="col-lg-4" id="BranchPayment" style="display:none;">
                            <div class="form-group">
                                <label class="control-label mb-1">Branch<b style="color:red">*</b></label>
                                <select name="ddlPayBranch" id="ddlPayBranch" class="form-control">
                                    <option value="0"> ------- Select ------- </option>

                                </select>
                                <label id="ddlPayBranch-error" class="error" for="ddlPayBranch" style="display:block"></label>

                            </div>
                        </div>
                    </div>

                    <br />
                    <br />
                    
                    <div id="others" style="display:none">
                        <div class="col-lg-12">
                            <div class="card">
                                <div class="card-footer">
                                    Add Entry
                                </div>
                                <div class="card-body card-block">
                                    <div class="row form-group">
                                        <div class="col-lg-4" id="debitAcc">
                                            <div class="form-group">
                                                <label for="cc-payment" class="control-label mb-1">Account<b style="color:red">*</b></label>
                                                <select name="ddlDebitAcc" id="ddlDebitAcc" class="form-control">
                                                    <option value="0"> ------------ Select ------------ </option>

                                                </select>
                                                <label id="ddlDebitAcc-error" class="error" for="ddlDebitAcc" style="display:block"></label>
                                            </div>
                                        </div>

                                        <div class="col-lg-2" id="debitSubAcc" style="display:none;">
                                            <div class="form-group">
                                                <label for="cc-payment" class="control-label mb-1">Sub Account<b style="color:red">*</b></label>
                                                <select name="ddlDebitSubAcc" id="ddlDebitSubAcc" class="form-control">
                                                    <option value="0"> ------------ Select ------------ </option>

                                                </select>
                                                <label id="ddlDebitSubAcc-error" class="error" for="ddlDebitSubAcc" style="display:block"></label>
                                            </div>
                                        </div>

                                        <div class="col-lg-2" id="debitAmtdiv">
                                            <div class="form-group">
                                                <label class="control-label mb-1">Debit Amount<b style="color:red">*</b></label>
                                                <input type="text" id="debitAmt" name="debitAmt" placeholder="" class="form-control" maxlength="6" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');">
                                                <label id="debitAmt-error" class="error" for="debitAmt" style="display:block"></label>

                                            </div>
                                        </div>

                                        <div class="col-lg-2" id="creditAmtdiv">
                                            <div class="form-group">
                                                <label class="control-label mb-1">Credit Amount<b style="color:red">*</b></label>
                                                <input type="text" id="creditAmt" name="creditAmt" placeholder="" class="form-control" maxlength="6" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');">
                                                <label id="creditAmt-error" class="error" for="creditAmt" style="display:block"></label>

                                            </div>
                                        </div>

                                        <div class="col-lg-4" id="tdsCategory">
                                            <div class="form-group">
                                                <label for="cc-payment" class="control-label mb-1">TDS Category</label> &nbsp; <input type="checkbox" id="tdscheck" />
                                                <select name="ddltdsCat" id="ddltdsCat" class="form-control">
                                                    <option value="0"> ------------ Select ------------ </option>

                                                </select>
                                                <label id="ddltdsCat-error" class="error" for="ddltdsCat" style="display:block"></label>
                                            </div>
                                        </div>
                                        <div class="col-lg-2" id="tdspercentage" style="display:none;">
                                            <div class="form-group">
                                                <label class="control-label mb-1">TDS Amount</label>
                                                <input type="text" id="tdsamt" name="tdsamt" placeholder="" class="form-control text-uppercase" maxlength="5" max="50" value="0" oninput="this.value = this.value.replace(/[^0-9.]/g, '');" />
                                                <label id="tdsamt-error" class="error" for="tdsamt" style="display:block"></label>

                                            </div>
                                        </div>
                                    </div>

                                    <div class="row form-group">
                                        <div class="col-lg-12 col-md-6 col-sm-12 col-xs-12">
                                            <div class="form-group">
                                                <label class="control-label mb-1">Remarks</label><b style="color:red">*</b>
                                                <input type="text" id="remarks" name="remarks" placeholder="" class="form-control text-uppercase" maxlength="150" oninput="this.value = this.value.replace(/[^a-zA-Z0-9., ]/g, '');">
                                                <label id="remarks-error" class="error" for="remarks" style="display:block"></label>

                                            </div>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <button type="button" class="btn btn-dark" id="add">Add</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card" id="maincard" style="display:none;margin-top: 20px;">
                        <div class="card-body" style="background-color:#fff !important; ">
                            <div class="table-responsive">
                                <div align="center" id="divdespatch" name="divdespatch" style="position: relative;min-height:100px;overflow: auto;display: block;">
                                    <table class="table" id="tbldespatch">
                                        <thead>
                                            <tr>
                                                <th class="VCol" style="text-align:left;">SL NO</th>
                                                <th class="VCol" style="text-align:left; display:none;">ACCOUNT NO</th>
                                                <th class="VCol" style="text-align:left;">ACCOUNT</th>
                                                <th class="VCol" style="text-align:left; display:none;">SUB ACCOUNT NO</th>
                                                <th class="VCol" style="text-align:left;">SUB ACCOUNT</th>
                                                <th class="VCol" style="text-align:left;">DESCRIPTION</th>
                                                <th class="VCol" style="text-align:left;">DEBIT</th>
                                                <th class="VCol" style="text-align:left;">CREDIT</th>
                                                <th class="VCol" style="text-align:left;">ACTION</th>
                                            </tr>
                                        </thead>
                                        <tbody id="paymenttabl"></tbody>
                                    </table>

                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="confirm" class="text-right" style="display:none;">
                        <button type="button" class="btn btn-success" id="submit">Confirm</button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts{

    <script src="~/ClientApp/PaymentAtBranch/BranchEntry.js"></script>
    <script src="~/ClientApp/PaymentAtBranch/InvoiceWebcamFile.js"></script>

}