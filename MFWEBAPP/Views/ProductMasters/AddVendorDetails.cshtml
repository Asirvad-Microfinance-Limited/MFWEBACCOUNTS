@{
    ViewData["Title"] = "AddVendor";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header"><strong> Add Vendor Details   </strong> </div>
            <div class="card-body">

                <form name="frmAddVendorDetails" id="frmAddVendorDetails" method="post">

                    <fieldset>
                        <legend class="legendcls">Vendor Details</legend>

                        <div class="row form-group">
                            <div class="col col-md-2 col-sm-6 col-xs-12">
                                <label for="street" class=" form-control-label">GST Type<b style="color:red">*</b></label>
                                <select placeholder="GST Type" id="ddlGstType" name="ddlGstType" class="form-control form-control">
                                    <option value="0"> ------- Select ------- </option>
                                    <option value="1">Registered</option>
                                    <option value="2">Not Registered</option>
                                </select>
                                <label id="ddlGstType-error" class="error" for="ddlGstType" style="display:block"></label>

                            </div>
                            <div class="col col-md-2 col-sm-6 col-xs-12">

                                <label for="street" class=" form-control-label" >GST Number<b style="color:red">*</b></label>
                                <input type="text" style="text-transform:uppercase" placeholder="GST Number" id="gstNo" name="gstNo" class="form-control" maxlength="15">
                                <label id="gstNo-error" class="error" for="gstNo" style="display:block"></label>

                            </div>
                            <div class="col col-md-4 col-sm-6 col-xs-12">

                                <label for="street" class=" form-control-label">Name<b style="color:red">*</b></label>
                                <input type="text" placeholder="Name" id="vname" name="vname" class="form-control" maxlength="35">
                                <label id="vname-error" class="error" for="vname" style="display:block"></label>

                            </div>
                            <div class="col col-md-4 col-sm-6 col-xs-12">

                                <label for="street" class=" form-control-label">Address<b style="color:red">*</b></label>
                                <input type="text" placeholder="Address" id="vaddress" name="vaddress" class="form-control" maxlength="95">
                                <label id="vaddress-error" class="error" for="vaddress" style="display:block"></label>

                            </div>
                        </div>

                        @*<div class="row form-group">


                            </div>*@

                        <div class="row form-group">
                            <div class="col col-md-3 col-sm-6 col-xs-12">
                                <label for="street col-sm-6 col-xs-12" class=" form-control-label">PAN<b style="color:red">*</b></label>
                                <input type="text" style="text-transform:uppercase" placeholder="PAN" id="panNo" name="panNo" class="form-control" maxlength="10">
                                <label id="panNo-error" class="error" for="panNo" style="display:block"></label>

                            </div>

                            <div class="col col-md-3 col-sm-6 col-xs-12">
                                <label for="street" class=" form-control-label">Pincode<b style="color:red">*</b></label>
                                <input type="text" id="pincode" name="pincode" placeholder="Pincode" class="form-control" maxlength="6">
                                <label id="pincode-error" class="error" for="pincode" style="display:block"></label>

                            </div>
                            <div class="col col-md-3 col-sm-6 col-xs-12">
                                <label for="street" class=" form-control-label">Post Office<b style="color:red">*</b></label>
                                <select name="ddlPostOffice" id="ddlPostOffice" placeholder="Post Office" class="form-control">
                                    <option value="0">--------------Select----------</option>
                                </select>
                                <label id="ddlPostOffice-error" class="error" for="ddlPostOffice" style="display:block"></label>
                                <input type="hidden" id="stateId" name="stateId" class="form-control">
                            </div>
                            <div class="col col-md-3 col-sm-6 col-xs-12">
                                <label for="street" class=" form-control-label">District<b style="color:red">*</b></label>
                                <input type="text" name="district" id="district" placeholder="District" class="form-control form-control" readonly>
                                @*<option value="0">--------------Select----------</option>*@
                                <label id="district-error" class="error" for="district" style="display:block"></label>
                            </div>
                        </div>

                        <div class="row form-group">
                            <div class="col col-md-3 col-sm-6 col-xs-12">
                                <label for="street" class=" form-control-label">State<b style="color:red">*</b></label>

                                <input type="text" name="state" id="state" placeholder="State" class="form-control form-control" readonly>
                                @*<option value="0">--------------Select----------</option>*@
                                @*<option value="1">Option #1</option>
                                    <option value="2">Option #2</option>
                                    <option value="3">Option #3</option>*@
                                @*</select>*@
                                <label id="state-error" class="error" for="state" style="display:block"></label>

                            </div>
                            <div class="col col-md-3 col-sm-6 col-xs-12">
                                <label for="street col-sm-6 col-xs-12" class=" form-control-label">Country<b style="color:red">*</b></label>
                                <input type="text" name="country" id="country" placeholder="Country" class="form-control form-control" readonly>
                                <label id="country-error" class="error" for="country" style="display:block"></label>

                                @*<option value="0">--------------Select----------</option>*@
                                @*<option value="1">Option #1</option>
                                    <option value="2">Option #2</option>*@
                                @*<option value="3">Option #3</option>
                                    </input>*@
                            </div>
                            <div class="col col-md-6 col-sm-6 col-xs-12">
                                <label for="street" class=" form-control-label">Email - ID<b style="color:red">*</b></label>
                                <input type="text" placeholder="Email - ID" id="emailId" name="emailId" class="form-control" maxlength="20" autocomplete=off >
                                <label id="emailId-error" class="error" for="emailId" style="display:block"></label>

                            </div>
                        </div>
                        @*<div class="row form-group">


                            </div>*@
                    </fieldset>

                    <br />


                    <fieldset>
                        <legend class="legendcls">Contact Person Details</legend>
                        @*<div class="col-lg-12" style="border:1px solid #5c9168; background-color:#f2ebec">*@

                        <div class="row form-group">
                            <div class="col col-md-6 col-sm-6 col-xs-12">
                                <label for="street" class="form-control-label">Contact Person Name<b style="color:red">*</b></label>
                                <input type="text" placeholder="Contact Person" id="contactPerson" name="contactPerson" class="form-control" maxlength="45">
                                <label id="contactPerson-error" class="error" for="contactPerson" style="display:block"></label>

                            </div>
                            <div class="col col-md-6 col-sm-6 col-xs-12">
                                <label for="street" class=" form-control-label">Contact Number<b style="color:red">*</b></label>
                                <input type="text" placeholder="Contact Number" id="contactNo" name="contactNo" class="form-control" maxlength="10">
                                <label id="contactNo-error" class="error" for="contactNo" style="display:block"></label>

                            </div>

                        </div>
                        @*</div>*@
                    </fieldset>
                    <br />

                    @*<div class="col-lg-12" style="border:1px solid #5c9168; background-color:#B1B3D7;">*@


                    <fieldset>
                        <legend class="legendcls">Bank Account Verification</legend>


                        <div class="row form-group">
                            <div class="col col-md-6 col-sm-6 col-xs-12">
                                <label for="street" class="form-control-label">IFSC Code<b style="color:red">*</b></label>
                                <input type="text" style="text-transform:uppercase" placeholder="IFSC Code" id="ifsc" name="ifsc" class="form-control" maxlength="11">
                                <label id="ifsc-error" class="error" for="ifsc" style="display:block"></label>

                            </div>
                            @*<div class="row ">
                                    <div class="col-lg-3 col-md-3 col-sm-3 col-xs-2">
                                        <label for="street" class="form-control-label"></label>
                                        <button type="button" class="btn btn-primary" id="ifscSearch"><i class="fa fa-search"></i></button>
                                    </div>
                                </div>*@

                            <div class="col col-md-6 col-sm-6 col-xs-12">
                                <label for="street" class=" form-control-label">Name of the Bank<b style="color:red">*</b></label>
                                <input type="text" placeholder="Name of the Bank" id="bankName" name="bankName" readonly class="form-control" maxlength="30">
                                <label id="bankName-error" class="error" for="bankName" style="display:block"></label>

                            </div>
                        </div>

                        <div class="row form-group">

                            <div class="col col-md-6 col-sm-6 col-xs-12">
                                <label for="street" class=" form-control-label">Account Number<b style="color:red">*</b></label>
                                <input type="password" placeholder="Account Number" id="accNo" name="accNo" class="form-control" autocomplete="off" minlength="9" maxlength="18" >
                                <label id="accNo-error" class="error" for="accNo" style="display:block"></label>

                            </div>
                            <div class="col col-md-6 col-sm-6 col-xs-12">
                                <label for="street" class=" form-control-label">Confirm Account Number<b style="color:red">*</b></label>
                                <input type="text" placeholder="Confirm Account Number" id="confirmAccNo" name="confirmAccNo" class="form-control" minlength="9" maxlength="18" >
                                <label id="confirmAccNo-error" class="error" for="confirmAccNo" style="display:block"></label>

                            </div>
                        </div>
                        <div id="divShowBankDetails" name="divShowBankDetails">
                            <div class="row form-group">



                                <div class="col col-md-4 col-sm-6 col-xs-12">
                                    <label for="street" class=" form-control-label">Account Holder Name<b style="color:red">*</b></label>
                                    <input type="text" id="accHolderName" name="accHolderName" class="form-control" readonly maxlength="30">
                                    @*<label id="accNo-error" class="error" for="accNo" style="display:block"></label>*@

                                </div>
                                <div class="col col-md-4 col-sm-6 col-xs-12">
                                    <label for="street" class=" form-control-label">Branch Name<b style="color:red">*</b></label>
                                    <input type="text" id="branchName" name="branchName" class="form-control" readonly maxlength="30">
                                    @*<label id="confirmAccNo-error" class="error" for="confirmAccNo" style="display:block"></label>*@

                                </div>


                                <div class="col col-md-4 col-sm-6 col-xs-12">

                                    @*<div class="card-shadow-danger mb-3 widget-chart widget-chart2 text-left card">*@
                                    <div class="widget-content p-0 w-100">
                                        <div class="widget-content-outer">
                                            <div class="widget-content-wrapper">
                                                <div class="widget-content-left pr-2 fsize-1">
                                                    <div id="divpercentValue" class="widget-numbers mt-0 fsize-3 text-success"></div>
                                                </div>
                                                <div class="widget-content-right w-100">
                                                    <div class="progress-bar-xs progress" style="height:4px;">
                                                        <div class="progress-bar bg-success" role="progressbar" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100" style="height:4px;"></div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="widget-content-left fsize-1">
                                                <div class="text-muted opacity-6">Name Matching Percentage</div>
                                            </div>
                                        </div>
                                        @*</div>*@
                                    </div>



                                </div>
                            </div>
                        </div>


                    </fieldset>
                    <!--Modal-->
                    <br />

                    <!--ModalEnd-->
                    <fieldset>
                        <legend class="legendcls">Mobile Number Verification</legend>


                        <div class="row form-group">

                            <div class="col col-lg-4 col-md-6 col-sm-12 col-xs-12">
                                <label for="street col-sm-6 col-xs-12" class=" form-control-label">Mobile Number<b style="color:red">*</b></label>
                                <input type="text" placeholder="Mobile" id="mobileNo" name="mobileNo" maxlength="10" class="form-control">
                                <label id="mobileNo-error" class="error" for="mobileNo" style="display:block"></label>

                            </div>

                            <div class="row form-group">
                                <div class="col col-lg-3 col-md-3 col-sm-12 col-xs-12">
                                    <label for="street" class="form-control-label"></label>
                                    <button type="button" class="btn btn-primary" id="btnsend" name="btnsend"> Send</button>
                                </div>
                            </div>
                            <div class="col col-lg-3 col-md-3 col-sm-12 col-xs-12">
                                <label for="street" class="form-control-label">OTP<b style="color:red">*</b></label>
                                <input type="text" placeholder="OTP" id="otp" name="otp" class="form-control" maxlength="6" disabled>
                                <label id="otp-error" class="error" for="otp" style="display:block"></label>

                            </div>
                            @*<div class="row form-group">
                                    <div class="col col-lg-3 col-md-3 col-sm-12 col-xs-12">
                                        <label for="street" class="form-control-label"></label>
                                        <button type="button" class="btn btn-primary" id="btnverifymobile" name="btnverifymobile"><i class="fa fa-check-square-o"></i></button>
                                    </div>
                                </div>*@
                        </div>
                    </fieldset>

                    <!--Modal-->
                    <!--ModalEnd-->
                    <br />


                    <br />


                    <div class="text-right">
                        <button type="submit" class="btn btn-success  waves-effect" style="font-size: 15px;" name="save" id="save" value="save" onclick="">Save</button>
                        @*<button type="submit" id="save" name="save" class="btn btn-success waves-effect"><i class="fa fa-save"></i> &nbsp;Save </button>*@

                    </div>




                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts{
    <script src="~/ClientApp/AddVendorDetails/AddVendorDetailsForm.Controller.js"></script>
    <script src="~/ClientApp/AddVendorDetails/AddVendorDetailsForm.Validator.js"></script>

}
