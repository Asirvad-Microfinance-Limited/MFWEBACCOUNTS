
@{
    ViewData["Title"] = "Customer Statement";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}

<div class="card">
    <div class="card-body" @*style="height: 355px;" *@>
        <h3 class="card-title">Customer Statement</h3>
        <div class="row">
            <div class="col-md-2">
                <div class="form-group" id="DivFrmDate">
                    <label>From Date</label>
                    <input type="text" class="form-control datepicker" id="FrmDate" name="FrmDate">
                </div>
            </div>
            <div class="col-md-2">
                <div class="form-group" id="DivToDate">
                    <label>To Date</label>
                    <input type="text" class="form-control datepicker" id="ToDate" name="ToDate">
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>Branch</label>
                    <select name="BranchID" id="BranchID" class=" form-control">
                        <option value="0">Select Branch</option>
                    </select>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>Center</label>
                    <select name="CenterID" id="CenterID" class=" form-control">
                        <option value="0">Select Center</option>
                    </select>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>Customer</label>
                    <select name="CustomerID" id="CustomerID" class=" form-control">
                        <option value="0">Select Customer</option>
                    </select>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>Loans</label>
                    <select name="LoanID" id="LoanID" class=" form-control">
                        <option value="0">Select Loan</option>
                    </select>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>Account</label>
                    <select name="AccountID" id="AccountID" class=" form-control">
                        <option value="0">Select Account</option>
                    </select>
                </div>
            </div>
            <div class="col-md-2">
                <div class="form-group" style="padding-top: 20px;">
                    <label>&nbsp;</label>
                    <button class="btn btn-success" id="btnSearch"><i class="fa fa-search"></i>&nbsp;Search</button>
                </div>
            </div>
        </div>
        <div class="row">
            &nbsp;
        </div>
        <div class="row">
            <div class="col-md-12">
                <table id="tblAccountsRetA" class="table table-bordered table-hover table-striped" width="100%">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Transaction</th>
                            <th>Description</th>
                            <th style="text-align:right;">Debit</th>
                            <th style="text-align:right;">Credit</th>
                            <th style="text-align:right;">Balance</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                    <tfoot>
                        <tr>
                            <td></td>
                            <td></td>
                            <td style="text-align:right;font-weight: 625;" id="TotDrAmt">0.00</td>
                            <td style="text-align:right;font-weight: 625;" id="TotCrAmt">0.00</td>
                        </tr>
                    </tfoot>
                </table>
                <table id="tblAccountsRetB" width="100%" class="table table-bordered table-hover table-striped" hidden>
                    <thead>
                        <tr>
                            <th>Account No</th>
                            <th>Account Name</th>
                            <th style="text-align:right;">Debit</th>
                            <th style="text-align:right;">Credit</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@section Scripts{
    <script src="~/lib/bootstrap/dist/assets/js/DataTable/jquery.dataTables.min.js"></script>
    <script src="~/Script/CustomerStatement.js"></script>

}