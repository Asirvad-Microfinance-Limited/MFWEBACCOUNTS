@{
    ViewData["Title"] = "Reports";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}
<style type="text/css">
    .table tbody tr:hover {
        background-color: #f5f5f5 !important;
    }

    table thead th {
        color: #292b35;
        background-color: #f2f0e8;
    }

    table, th {
        border: 2px solid #fff !important;
    }

    .hide {
        display: none !important;
    }
</style>
<div id="Loader" class="page-loader-wrapper">
    <div class="loader">
        <div class="preloader">
            <div class="spinner-layer pl-blue-grey">
                <div class="circle-clipper left">
                    <div class="circle"></div>
                </div>
                <div class="circle-clipper right">
                    <div class="circle"></div>
                </div>
            </div>
        </div>
        <p style="color:#dbb714;font-family:'Myanmar Text'">Please Wait...</p>
    </div>
</div>
<div>
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" id="rptHeadName"><strong> REPORTS </strong></div>
            <div class="card-body card-block">
                <form name="frmMicroReport" id="frmMicroReport" method="post">
                    <div class="row">
                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-4">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1">Reports<b style="color:red">*</b></label>
                                <select name="ddlMicrRptName" id="ddlMicrRptName" class="form-control">
                                    <option value="0">Select</option>
                                </select>
                                <label id="ddlMicrRptName-error" class="error" for="ddlMicrRptName" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-2 col-sm-2 col-xs-2" id="bs_datepicker_container1" style="display: none;">
                            <div class="form-group">
                                <label for="datepicker" class=" form-control-label mb-1">Date<b style="color:red">*</b></label>
                                <input class="form-control datepicker " id="dtFromDate" name="dtFromDate" placeholder="UDAIP" type="text" readonly />
                                <label id="dtFromDate-error" class="error" for="dtFromDate" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-2 col-sm-2 col-xs-2" id="bs_datepicker_container2" style="display: none;">
                            <div class="form-group">
                                <label for="datepicker" class=" form-control-label mb-1">To Date<b style="color:red">*</b></label>
                                <input class="form-control datepicker " id="dtToDate" name="dtToDate" placeholder="DD/MM/YYYY" type="text" readonly />
                                <label id="dtToDate-error" class="error" for="dtToDate" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-3" id="DivddlDynCombo1" style="display: none;">
                            <div class="form-group">
                                <label for="cc-payment" id="lblDynCombo1" class="control-label mb-1">Select <b style="color:red">*</b></label>
                                <select name="ddlDynCombo1" id="ddlDynCombo1" class="form-control">
                                    <option value="0">Select</option>
                                </select>
                                <label id="ddlDynCombo1-error" class="error" for="ddlDynCombo1" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-2 col-sm-2 col-xs-2" id="DivddlDynCombo2" style="display: none;">
                            <div class="form-group">
                                <label for="cc-payment" id="lblDynCombo2" class="control-label mb-1">Select <b style="color:red">*</b></label>
                                <select name="ddlDynCombo2" id="ddlDynCombo2" class="form-control">
                                    <option value="0">Select</option>
                                </select>
                                <label id="ddlDynCombo2-error" class="error" for="ddlDynCombo2" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-2 col-sm-2 col-xs-2" id="DivddlDynCombo3" style="display: none;">
                            <div class="form-group">
                                <label for="cc-payment" id="lblDynCombo3" class="control-label mb-1">Select <b style="color:red">*</b></label>
                                <select name="ddlDynCombo3" id="ddlDynCombo3" class="form-control">
                                    <option value="0">Select</option>
                                </select>
                                <label id="ddlDynCombo3-error" class="error" for="ddlDynCombo3" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-2 col-sm-2 col-xs-2" id="DivtxtDyn1" style="display: none;">
                            <div class="form-group">
                                <label for="cc-payment" id="lblDyn1" class="control-label mb-1">Select <b style="color:red">*</b></label>
                                <input type="text" class="form-control" placeholder="" id="txtDyn1" name="txtDyn1" maxlength="16" />
                                <label id="txtDyn1-error" class="error" for="txtDyn1" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-2 col-sm-2 col-xs-2" id="DivtxtDyn2" style="display: none;">
                            <div class="form-group">
                                <label for="cc-payment" id="lblDyn2" class="control-label mb-1"><b style="color:red">*</b></label>
                                <input type="text" class="form-control" placeholder="" id="txtDyn2" name="txtDyn2" maxlength="16" />
                                <label id="txtDyn2-error" class="error" for="txtDyn2" style="display:block"></label>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-2 col-sm-2 col-xs-2" id="DivtxtDyn3" style="display: none;">
                            <div class="form-group">
                                <label for="cc-payment" id="lblDyn3" class="control-label mb-1"><b style="color:red">*</b></label>
                                <input type="text" class="form-control" placeholder="" id="txtDyn3" name="txtDyn3" maxlength="16" />
                                <label id="txtDyn3-error" class="error" for="txtDyn3" style="display:block"></label>
                            </div>
                        </div>
                        <br />
                    </div>
                    <div class="row">
                        <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4 btnwrap" style="margin-left:82%;">
                            <button type="button" id="btnMicroSubmit" name="btnMicroSubmit" class="btnsmall btn-danger" style="margin-left:2%;"> <i class="fa fa-eye" title="View" style="font-size:20px;margin-top: 4px;"></i></button>
                            <button type="button" id="btnexport" name="btnexport" class="btnsmall btn-danger" style="margin-left:2%;"> <i class="fa  fa-file-excel-o" title="Excel" style="font-size:20px;margin-top: 4px;"></i></button>
                            <button type="button" id="btnPdf" name="btnPdf" class="btnsmall btn-danger" style="margin-left:2%;"> <i class="fa  fa-file-pdf-o" title="PDF" style="font-size:20px;margin-top: 4px;"></i></button>
                        </div>
                    </div>
                    <!--Table-->
                    <div class="row">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xl-12 no-padding">
                            <div class="card" id="maincard" style="display:none;min-height:250px">
                                <div class="card-body" style="background-color:#fff !important;">
                                    <div class="table-responsive">
                                        <div id="exportpdf">
                                            <div class="row">
                                                <div class="col-md-12">
                                                    <h5 class="form-control-label" id="DateHeading" style="text-align:right;"></h5>
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col-md-12">
                                                    <H4 class="form-control-label" id="Heading" style="text-align:center;font-weight:bold;padding-bottom: 10px;"></H4>
                                                </div>
                                            </div>
                                            <fieldset id="custDetailsDiv" style="margin-bottom:10px;">
                                                <div class="row " style="margin-bottom:8px;margin-left:-2px;margin-right:-3px;color:black;" id="custDetailsDiv1" name="custDetailsDiv">
                                                    <div class="col-lg-3 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="street" class="form-control-label" id="custLabel1"></label>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-3 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="street" class="form-control-label" id="custLabel2"></label>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-3 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="street" class="form-control-label" id="custLabel3"></label>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-3 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="street" class="form-control-label" id="custLabel4"></label>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row " style="margin-left:-2px;margin-right:-3px;color:black;" id="custDetailsDiv2" name="custDetailsDiv2">
                                                    <div class="col-lg-3 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="street" class="form-control-label" id="custLabel5"></label>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-3 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="street" class="form-control-label" id="custLabel6"></label>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-3 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="street" class="form-control-label" id="custLabel7"></label>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-3 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="street" class="form-control-label" id="custLabel8"></label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </fieldset>
                                            <button type="button" style="margin-top:0px;margin-bottom:7px;background:#e5322d;margin-left: 90%;" class="btnsmall btn-danger" id="backButton" name="backButton"><i class="ti-control-backward" style="font-size:10px;"></i> Back</button>
                                            <div class="row">
                                                <div class="col-md-12">
                                                    <div id="divMicroRptTable" name="divMicroRptTable "></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@*---------------- My Modal ----------------*@
<div class="modal fade" id="ImageModel" tabindex="-1" role="dialog" aria-labelledby="Modal1" aria-hidden="true" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="largeModalLabel">Image</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-12" id="ImageDiv" style="text-align:center;">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div align="center" class="col-lg-12">
                    <button type="button" id="rtt" data-dismiss="modal" aria-label="Close" class="btn btn-primary"><i class="fa fa-close"></i>&nbsp;Close</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {


    <script src="~/ClientApp/Reports/Reports.Controller.js"></script>
    <script src="~/lib/bootstrap/dist/assets/js/DataTable/jquery.dataTables.min.js"></script>
    <script src="~/lib/bootstrap/dist/assets/js/DataTable/dataTables.bootstrap4.min.js"></script>
    <script src="~/lib/bootstrap/dist/assets/js/DataTable/dataTables.responsive.min.js"></script>
    <script src="~/lib/bootstrap/dist/assets/js/DataTable/responsive.bootstrap4.min.js"></script>
    <script src="~/lib/bootstrap/dist/assets/js/DataTable/dataTables.buttons.min.js"></script>
    <script src="~/lib/bootstrap/dist/assets/js/DataTable/buttons.print.min.js"></script>
    <link href="~/lib/Plugins/LoaderWrapper/Loginstyle.css" rel="stylesheet" />

}

