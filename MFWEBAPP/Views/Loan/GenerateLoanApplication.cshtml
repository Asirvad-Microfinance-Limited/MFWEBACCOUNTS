
@{
    ViewData["Title"] = "GenerateLoanApplication";
    Layout = "~/Views/Shared/_MFMainLayout.cshtml";
}


<link href="~/lib/bootstrap/dist/assets/css/Print.css" rel="stylesheet" />


<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header"><strong> Print Loan Application </strong></div>
            <div class="card-body card-block">
                <form name="PrintLoanApplication" id="PrintLoanApplication" method="post">
                    <!--Branch-->

                    <div class="row">

                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1">Branch<b style="color:red">*</b></label>
                                <select name="ddlBranches" id="ddlBranches" class=" form-control">
                                    <option value="0">--------------Select----------</option>
                                    @*<option value="1">Option #1</option>
            <option value="2">Option #2</option>
            <option value="3">Option #3</option>*@
                                </select>
                                <label id="ddlBranches-error" class="error" for="ddlBranches" style="display:block"></label>

                            </div>
                        </div>

                        <!--Center-->

                        <div class="col-lg-3 col-md-6 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label for="cc-payment" class="control-label mb-1">Center<b style="color:red">*</b></label>
                                <select name="ddlCenters" id="ddlCenters" class=" form-control">
                                    <option value="0">------------Select------------------</option>
                                    @*<option value="1">Option #1</option>
            <option value="2">Option #2</option>
            <option value="3">Option #3</option>*@
                                </select>
                                <label id="ddlCenters-error" class="error" for="ddlCenters" style="display:block"></label>

                            </div>
                        </div>

                    </div>

                    <div class="col-lg-12 col-md-12 col-sm-12 col-xl-12 no-padding">
                        <div class="card" id="maincard" style="display:none;">
                            <div class="card-body" style="background-color:#fff !important;">

                                <div class="table-responsive">

                                    <div align="center" id="divloanapplicationtable" name="divloanapplicationtable" style="position: relative;max-height: 350px;min-height:100px;overflow: auto;display: block;">

                                    </div>

                                </div>
                            </div>
                        </div>
                        <div class="text-center">
                            @*<button type="submit" id="printSubmit" name="printSubmit" class="btn btn-danger fc-center"><i class="fa fa-print"></i> &nbsp;Print </button>*@
                            
                        </div>

                        <div class="row clearfix">
                            <div class="col-md-12">
                                @*<div id="printable" style="display:none;">*@
                                <div id="generatedloanapplication" style="display:none;">

                                </div>

                            </div>
                        </div>

                    </div>


                </form>
                    <!--Table-->

                    
            </div>
        </div>

    </div>
</div>


@section Scripts{
    <link href="~/lib/bootstrap/dist/assets/css/Print.css" rel="stylesheet" />
    <script src="~/ClientApp/GenerateLoanApplication/GenerateLoanApplication.Validator.js"></script>
    <script src="~/ClientApp/GenerateLoanApplication/GenerateLoanApplication.Controller.js"></script>

}